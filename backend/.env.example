# ─────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────
NODE_ENV=development
PORT=8080

# ─────────────────────────────────────────
# DATABASE — Neon PostgreSQL
# Format: postgresql://user:password@host/dbname?sslmode=require
# ─────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxxxx.us-east-1.aws.neon.tech/stackly?sslmode=require

# ─────────────────────────────────────────
# JWT
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────
JWT_ACCESS_SECRET=your_access_secret_minimum_32_characters
JWT_REFRESH_SECRET=your_refresh_secret_minimum_32_characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────
# CORS
# ─────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100